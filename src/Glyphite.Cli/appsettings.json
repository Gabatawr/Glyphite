{
  "Glyphite": {
    "LLM": {
      "Endpoint": "https://api.deepseek.com/v1",
      "ApiKey": "",
      "Model": "deepseek-v4-flash",
      "ContextWindow": 1000000,
      "ReasoningEffort": "High",
      "Models": [
        { "Name": "deepseek-v4-flash", "Miss": 0.14, "Hit": 0.0028, "Output": 0.28 },
        { "Name": "deepseek-v4-pro", "Miss": 0.435, "Hit": 0.003625, "Output": 0.87 }
      ]
    },
    "Bash": {
      "ExecutablePath": "bash",
      "DiscoveryTimeoutMs": 3000,
      "DefaultTimeoutMs": 120000,
      "MaxOutput": 100000,
      "ForbiddenCommands": ["sudo"]
    },
    "Memory": {
      "ProtectedBlockTypes": ["agent_data", "user_message", "agent_task", "agent_message", "turn"],
      "ReadAgentsFile": false,
      "TurnReloadAgentsFile": false,
      "TurnReloadNameFile": false
    },
    "ToolStreaming": {
      "ToolMaxLength": {
        "bash": -1,
        "bash_back": -1,
        "read_file": 0,
        "write_file": 0,
        "patch_file": 0,
        "memory": -1,
        "todo": -1,
        "fetch_web": 0,
        "search_glob": 0,
        "search_grep": 0,
        "subagent_run": -1,
        "subagent_use": -1
      },
      "ToolHiddenArgs": {
        "write_file": ["content"],
        "patch_file": ["old", "new"],
        "todo": ["title", "items"],
        "subagent_run": ["task"],
        "subagent_use": ["task"]
      }
    },
    "Search": {
      "ExcludedDirectories": [".git", "node_modules", "bin", "obj", ".vs", ".idea", ".vscode", "packages"],
      "BinaryExtensions": [".dll", ".exe", ".pdb", ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".ico", ".zip", ".tar", ".gz", ".7z", ".rar", ".pdf", ".doc", ".docx", ".mp3", ".mp4", ".avi", ".mov", ".wav", ".ogg", ".o", ".so", ".dylib", ".class", ".jar", ".war", ".ttf", ".otf", ".woff", ".woff2", ".eot"],
      "MaxResultCount": 100,
      "MaxTextFileSize": 1000000,
      "MaxLineLength": 2000,
      "DetectBinarySampleSize": 1024,
      "MaxEnumerationFiles": 50000,
      "MaxReadChars": 100000
    },
    "Data": {
      "Directory": "data",
      "DatabaseFileName": "Glyphite.db"
    },
    "WebFetch": {
      "TimeoutSeconds": 30,
      "UserAgent": "Glyphite/1.0",
      "MaxContentLength": 100000,
      "DefaultFormat": "text"
    },
    "Todo": {
      "ValidStatuses": ["pending", "in_progress", "done", "cancelled", "blocked"],
      "DefaultStatus": "pending",
      "DefaultPriority": "medium"
    },
    "McpServers": {
      "Servers": {}
    },
    "Compression": {
      "AutoThreshold": 20,
      "AutoCompress": true,
      "Strategies": {
        "fibo-parts": true,
        "struct-cut": false
      },
      "CacheHitRateThreshold": 80,
      "CostSignificantThreshold": 0.01
    },
    "ContentDedup": {
      "MinLines": 3,
      "FrequencyThreshold": 0.05,
      "MinLineLength": 32,
      "MaxAliases": 10,
      "AutoDedupExtensions": [".log"]
    },
    "Agent": {
      "MaxToolIterations": 100,
      "PeekReasoning": false,
      "PeekToolReasoning": false
    }
  }
}
